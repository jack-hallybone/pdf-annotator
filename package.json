{
  "name": "pdf-annotator",
  "private": true,
  "version": "0.1.0",
  "description": "A lightweight client-side PDF viewer and annotation tool written using Codex.",
  "type": "module",
  "scripts": {
    "predev": "node scripts/prepare-renderer-assets.mjs",
    "dev": "vite",
    "prebuild": "node scripts/prepare-renderer-assets.mjs",
    "build": "tsc -b && vite build && node scripts/generate-service-worker.mjs",
    "prepreview": "node scripts/prepare-renderer-assets.mjs",
    "preview": "vite preview",
    "prepare-assets": "node scripts/prepare-renderer-assets.mjs",
    "test": "npm run test:unit && npm run test:dom",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "test:dom": "TSX_TSCONFIG_PATH=./tests/tsconfig.json node --import tsx --import ./tests/dom-setup.ts --test tests/*.dom.test.tsx",
    "test:e2e": "playwright test",
    "security:audit": "npm audit && npm audit signatures",
    "lint": "eslint ."
  },
  "dependencies": {
    "lucide-react": "1.17.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "global-jsdom": "^29.0.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "8.0.16"
  }
}
