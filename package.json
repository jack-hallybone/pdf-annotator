{
  "name": "lightweight-pdf-annotator",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first lightweight PDF reader and annotator MVP.",
  "main": "dist-electron/electronapp/main.js",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-pdfjs-assets.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-pdfjs-assets.mjs",
    "build": "tsc -b && vite build",
    "electron:build": "tsc -p tsconfig.electron.json",
    "electron:dev": "npm run electron:build && ELECTRON_RENDERER_URL=http://127.0.0.1:5173 electron dist-electron/electronapp/main.js",
    "electron:preview": "npm run desktop:build && electron dist-electron/electronapp/main.js",
    "generate-icons": "node scripts/generate-electron-icon.mjs",
    "desktop:build": "npm run generate-icons && npm run build && npm run electron:build",
    "desktop:package:win": "npm run desktop:build && electron-builder --win portable --publish never",
    "desktop:package:win:installer": "npm run desktop:build && electron-builder --win nsis --publish never",
    "prepreview": "node scripts/copy-pdfjs-assets.mjs",
    "preview": "vite preview",
    "copy-pdfjs-assets": "node scripts/copy-pdfjs-assets.mjs",
    "security:audit": "npm audit && npm audit signatures"
  },
  "dependencies": {
    "lucide-react": "1.17.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "6.0.227",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "build": {
    "appId": "io.github.jackhallybone.pdf-annotator",
    "asar": true,
    "compression": "normal",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "extraMetadata": {
      "dependencies": {}
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "npmRebuild": false,
    "productName": "PDF Annotator",
    "publish": null,
    "fileAssociations": [
      {
        "description": "PDF document",
        "ext": "pdf",
        "icon": "icon.ico",
        "name": "PDF document",
        "role": "Editor"
      }
    ],
    "icon": "build/icon.ico",
    "nsis": {
      "allowToChangeInstallationDirectory": true,
      "artifactName": "PDF-Annotator-${version}-win-${arch}-setup.${ext}",
      "oneClick": false,
      "perMachine": true
    },
    "portable": {
      "artifactName": "PDF-Annotator-${version}-win-${arch}-portable.${ext}"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "arch": [
            "x64"
          ],
          "target": "portable"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
