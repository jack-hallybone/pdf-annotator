{
  "name": "lightweight-pdf-annotator",
  "private": true,
  "version": "0.1.0",
  "description": "A local-first lightweight PDF reader and annotator MVP.",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-pdfjs-assets.mjs",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node scripts/copy-pdfjs-assets.mjs",
    "build": "tsc -b && vite build",
    "prepreview": "node scripts/copy-pdfjs-assets.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "copy-pdfjs-assets": "node scripts/copy-pdfjs-assets.mjs",
    "security:audit": "npm audit && npm audit signatures"
  },
  "dependencies": {
    "lucide-react": "1.14.0",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "5.7.284",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vite": "7.3.3"
  }
}
